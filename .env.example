# Telegram 机器人配置
TG_BOT_TOKEN=8529056032:AAEOYyeLyRwfVBNQ_FJSn2drMQv7Y6YHcKg
TG_ALLOWED_CHAT_ID=6043857337

# 轮询
TG_POLL_TIMEOUT_SECONDS=20
TG_REPOLL_DELAY_MS=1500
# Telegram 访问代理，可选
TG_PROXY_URL=http://127.0.0.1:7890
# 走代理时建议开启短轮询，避免长连接接收超时
TG_USE_SHORT_POLL=true

# Ask 模式配置：普通文本消息会走这里
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4
OPENAI_PROXY_URL=

# Codex CLI 配置
ENABLE_CODEX=true
CODEX_WORKDIR=H:/project_public
# 可选：手动指定 Codex CLI 绝对路径，Windows 下推荐指向 codex.cmd 或 codex.exe
CODEX_CLI_PATH=
# 可选：true 时直接传 --dangerously-bypass-approvals-and-sandbox
CODEX_BYPASS_APPROVALS=false
# 留空时继承本机 ~/.codex/config.toml；可选 read-only / workspace-write / danger-full-access
CODEX_SANDBOX=
CODEX_MODEL=

# Web Codex Console
WEB_CODEX_HOST=127.0.0.1
WEB_CODEX_PORT=4631
# 建议自行设置固定访问令牌；留空时服务启动会打印临时令牌
WEB_CODEX_TOKEN=
WEB_CODEX_TIMEOUT_MS=900000

# Web Resume Console
WEB_RESUME_HOST=127.0.0.1
WEB_RESUME_PORT=4632
# 建议自行设置固定访问令牌；留空时服务启动会打印临时令牌
WEB_RESUME_TOKEN=
WEB_RESUME_TIMEOUT_MS=900000
WEB_RESUME_WORKDIR=

# iOS 推送通知（APNs）
PUSH_SERVICE_ENABLED=true
PUSH_DEFAULT_ENABLED=true
PUSH_NOTIFY_ON_COMPLETED=true
PUSH_NOTIFY_ON_ERROR=true
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
# 可填绝对路径，或相对 telegram-codex-bot 根目录的路径
APNS_PRIVATE_KEY_PATH=
# 开发调试阶段通常为 true；上架后切到 false
APNS_USE_SANDBOX=true
