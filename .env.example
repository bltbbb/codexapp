# Telegram 机器人配置
TG_BOT_TOKEN=8529056032:AAEOYyeLyRwfVBNQ_FJSn2drMQv7Y6YHcKg
TG_ALLOWED_CHAT_ID=6043857337

# 轮询
TG_POLL_TIMEOUT_SECONDS=20
TG_REPOLL_DELAY_MS=1500
# Telegram 访问代理，可选
TG_PROXY_URL=http://127.0.0.1:7890
# 走代理时建议开启短轮询，避免长连接接收超时
TG_USE_SHORT_POLL=true

# Ask 模式配置：普通文本消息会走这里
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4
OPENAI_PROXY_URL=

# Codex CLI 配置
ENABLE_CODEX=true
CODEX_WORKDIR=H:/project_public
# 可选：手动指定 Codex CLI 绝对路径，Windows 下推荐指向 codex.cmd 或 codex.exe
CODEX_CLI_PATH=
# 可选：true 时直接传 --dangerously-bypass-approvals-and-sandbox
CODEX_BYPASS_APPROVALS=false
# 留空时继承本机 ~/.codex/config.toml；可选 read-only / workspace-write / danger-full-access
CODEX_SANDBOX=
CODEX_MODEL=
